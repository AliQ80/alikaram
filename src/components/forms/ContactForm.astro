---
import { Button, FormInput, FormTextarea } from '@components/odyssey-theme';
---

<form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/contact-thank-you">
  <input type="hidden" name="form-name" value="contact" />
  <p class="hidden-field">
    <label>Don't fill this out if you're human: <input name="bot-field" /></label>
  </p>
  <FormInput type="text" label="Name" name="Name" placeholder="John Doe" />
  <FormInput type="email" label="Email" name="Email" placeholder="hello@example.com" />
  <FormTextarea label="Message" name="Message" placeholder="Your message here..." />
  <Button>Submit</Button>
</form>

<style>
  form {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .hidden-field {
    display: none;
  }
</style>