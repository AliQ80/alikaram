---
import { Icon } from 'astro-icon/components';
import { Container, Button } from '@components/odyssey-theme';
---

<Container>
	<section class="hero-section__section">
		<div class="hero-section__text">
			<h1>Ali Karam</h1>
			<p>Educator, software engineer, and robotics coach.</p>
			<div class="hero-btns__container">
				<Button href="/projects" outlined customIcon iconStart
					>View Projects <Fragment slot="icon"
						><Icon name="mdi:briefcase-outline" /></Fragment
					></Button
				>
				<Button href="/blog" outlined customIcon iconStart
					>Read the Blog <Fragment slot="icon"
						><Icon name="mdi:notebook-outline" /></Fragment
					></Button
				>
			</div>
		</div>
		<div class="hero-section__image">
			<picture>
				<img src="/assets/images/home/ali-karam-hero.jpg" alt="Ali Karam" />
			</picture>
		</div>
	</section>
</Container>

<style>
	.hero-section__section {
		margin: var(--section-margin) auto;
		min-height: clamp(90lvh, 100vw, calc(100lvh - var(--navbar-height)));
		display: grid;
		grid-template-columns: 1fr 1fr;
		align-items: center;
		gap: 1rem;
	}
	.hero-section__text {
		justify-self: center;
		max-width: 25rem;
		text-align: center;
	}
	.hero-btns__container {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		align-items: center;
		gap: 1rem;
	}
	.hero-btns__container {
		margin-right: 1rem;
	}
	.hero-section__image {
		display: flex;
		align-self: stretch;
	}
	.hero-section__image picture {
		width: 100%;
	}
	.hero-section__image img {
		width: 100%;
		height: 100%;
		max-height: 80lvh;
		object-fit: cover;
		object-position: top;
		border-radius: var(--theme-shape-radius);
	}
	@media (max-width: 768px) {
		.hero-section__section {
			grid-template-columns: 1fr;
		}
		.hero-btns__container {
			flex-direction: column;
			align-items: center;
			gap: 0.75rem;
		}
		.hero-btns__container :global(.btn) {
			width: 80%;
		}
	}
	@media (min-width: 769px) and (max-aspect-ratio: 4/5) {
		.hero-section__section {
			min-height: auto;
		}
		.hero-btns__container :global(.btn) {
			width: 80%;
		}
		.hero-section__image img {
			height: calc(100lvh - var(--navbar-height));
			max-height: calc(100lvh - var(--navbar-height));
		}
	}
</style>
