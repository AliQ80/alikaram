---
import { TextSection } from '@components/odyssey-theme';
import Layout from '../../layouts/Page.astro';
import HeroSection from '../../components/sections/heros/HeroSection.astro';

const seo = {
	title: 'About | Ali Karam',
	description: 'Educator, software engineer, and robotics coach based in Kuwait.',
};
---

<Layout {seo}>
	<HeroSection>
		<div slot="text-container">
			<h1>About Me</h1>
			<p>
				I've been coding since 1988, when I started with BASIC at age 13.
				These days I teach computer science to high schoolers and build web
				projects on the side.
			</p>
		</div>
    <picture slot="image-container">
      <img
        src="/assets/images/home/classic-hero.jpg"
        alt="Ali Karam"
        id="home-hero-image"
      />
    </picture>
	</HeroSection>
  <TextSection narrow>
    <p>
      I'm a Computer Science teacher at a high school, where I get to introduce
      the next generation of students to programming and robotics. Outside the
      classroom, I do web development — this site included.
    </p>
    <p>
      I've been writing code for close to four decades now, starting on BASIC
      back in 1988. That long a run means I've picked up a lot along the way,
      but I still enjoy learning new tools and languages as much as I did at 13.
    </p>
    <p>I'm based in Kuwait.</p>
  </TextSection>
</Layout>
