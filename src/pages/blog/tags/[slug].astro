---
import Layout from '../../../layouts/Page.astro'
import { Container } from '@components/odyssey-theme';
import {generateTagData} from '../../../utils/helpers.js'
import { getBlogPosts } from '../../../utils/blog.js';

export async function getStaticPaths() {
  const posts = getBlogPosts();
  const allCategoriesUnique = new Set();

  posts.forEach(post => {
    post.tags?.forEach(tag => allCategoriesUnique.add(tag));
  });

  const allCategoriesData = generateTagData(allCategoriesUnique);
  return allCategoriesData.map((tag) => ({
    params: { slug: tag.slug },
    props: {
      tag: tag.title,
      posts: posts.filter(post => post.tags?.includes(tag.title)),
    },
  }));
}

const {tag, posts} = Astro.props;

const seo ={
  title: `${tag} | Ali Karam`,
}
---

<Layout seo={seo}>
  <Container narrow>
    <section class="tag-page__section"> 
      <h1>Posts Tagged with "{tag}"</h1>
      <ul>
        {posts.map(post => (
          <li><a href={post.url}>{post.title}</a></li>
        ))}
      </ul>
    </section>
  </Container>
</Layout>

<style>
.tag-page__section {
  min-height: 60vh;
  margin: var(--section-margin);
}
</style>